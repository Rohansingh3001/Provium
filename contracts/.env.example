# ── Base Sepolia Network ────────────────────────────────────────────────────
BASE_SEPOLIA_RPC=https://sepolia.base.org
# Or use your own Alchemy/Infura RPC for reliability

# ── Deployer Wallet ──────────────────────────────────────────────────────────
# Must have Base Sepolia ETH for gas. Get FREE from:
# https://www.alchemy.com/faucets/base-sepolia
# https://faucet.quicknode.com/base/sepolia
DEPLOYER_PRIVATE_KEY=0x...

# ── Agent Wallet ────────────────────────────────────────────────────────────
# This wallet will be set as the agent address in contracts
# Must match AGENT_WALLET_ADDRESS in agent/.env
AGENT_WALLET_ADDRESS=0x...

# ── Basescan API Key (Optional - for contract verification) ───────────────────
BASESCAN_API_KEY=...
