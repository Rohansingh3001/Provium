NEXT_PUBLIC_LENDING_PROTOCOL=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_REGULATOR_PORTAL=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_COMPLIANCE_REGISTRY=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ULTRA_VERIFIER=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_AGENT_WALLET=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://sepolia.base.org

# Optional public metadata for bounty-track showcase
NEXT_PUBLIC_ENS_PROTOCOL_NAME=provium.eth
NEXT_PUBLIC_ENS_AGENT_NAME=provium-agent.eth
NEXT_PUBLIC_BITGO_MODE=ready
NEXT_PUBLIC_BITGO_WALLET_LABEL=Provium BitGo policy wallet
NEXT_PUBLIC_BITGO_POLICY=BitGo secures proof submission while ZK preserves protocol privacy.

# ── ENSIP-25 AI Agent Registry Verification ──────────────────────────────────
# ENSIP-25 ties provium-agent.eth to the ComplianceRegistry on-chain entry.
# The text record key is built as:
#   agent-registration[<erc7930_COMPLIANCE_REGISTRY>][<ENSIP25_AGENT_ID>]
# NEXT_PUBLIC_COMPLIANCE_REGISTRY above is used as the registry address (already set).
# Set NEXT_PUBLIC_ENSIP25_AGENT_ID to match the agentId in the registry (default: 1).
NEXT_PUBLIC_ENSIP25_AGENT_ID=1
