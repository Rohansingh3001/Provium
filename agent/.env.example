GROQ_API_KEY=gsk_...
# Get free at: https://console.groq.com → API Keys

BASE_SEPOLIA_RPC=https://sepolia.base.org
# Or your own Alchemy/Infura RPC for reliability

AGENT_PRIVATE_KEY=0x...
# This wallet MUST have Base Sepolia ETH for gas
# Must match AGENT_WALLET_ADDRESS set during contract deployment

AGENT_WALLET_ADDRESS=0x...

CIRCUITS_PATH=../circuits/collateral_proof
DEPLOYMENTS_PATH=../contracts/deployments/base-sepolia.json

# ── BitGo Integration (Bounty 1 — $1,200 pool) ────────────────────────────────
# BitGo multi-sig wallet secures every ZK proof submission.
# Setup: https://app.bitgo-test.com → Create account → Create tbaseeth wallet
#        → Settings → Developer → Create Access Token
BITGO_ACCESS_TOKEN=
BITGO_WALLET_ID=
BITGO_WALLET_PASSPHRASE=
BITGO_ENV=test
BITGO_COIN=tbaseeth

# ── ENSIP-25 AI Agent Registry Verification ──────────────────────────────────
# ENSIP-25 ties the agent's ENS name to its on-chain ComplianceRegistry entry.
# Reference: https://docs.ens.domains/ensip/25/
#
# The orchestrator logs the exact text record key to set on ENS at first startup:
#   agent-registration[<erc7930_registry>][<ENSIP25_AGENT_ID>] = "1"
#
# To print setup instructions:
#   python -m tools.ensip25
#
# ENSIP25_AGENT_ID: the index or identifier used when the agent was registered
#   in ComplianceRegistry. Default is "1" (first registered agent).
ENSIP25_AGENT_ID=1

# ── Fileverse Integration (Evidence Layer) ────────────────────────────────────
# Fileverse stores rich compliance dossiers (proof metadata, tx links, reasoning)
# as portable, encrypted-capable documents for regulator handoff.
# If not configured, dossiers are saved locally to agent/dossiers/ as fallback.
# Setup: https://fileverse.io → Get API key → Add below
FILEVERSE_API_KEY=
FILEVERSE_NAMESPACE=

